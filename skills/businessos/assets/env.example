# Chaves do BusinessOS — copie para .businessos/.env e preencha.
# Este arquivo (.businessos/.env) deve ficar fora do git (gitignore).

# --- Geração de imagem por IA (skill carrossel, foto IA opcional) ---
# Escolha um provider em .businessos/config.json (imagem.provider: openai|gemini).
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- Publicação em redes sociais (skill aprovar-post) ---
# Meta Graph API — Instagram Business + Página do Facebook.
META_PAGE_ACCESS_TOKEN=
META_PAGE_ID=
META_IG_USER_ID=

# --- Site (skills publicar-tema / aprovar-post) ---
# URL pública do site onde o blog e as imagens são servidos.
SITE_URL=
